
{
  "entities": {
    "Webhook": {
      "title": "Webhook",
      "description": "Registros de sinais recebidos",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "payload": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["timestamp", "payload", "createdAt"]
    },
    "AccessCode": {
      "title": "AccessCode",
      "description": "Códigos de acesso de clientes",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "usedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/webhooks/{webhookId}": {
      "schema": "Webhook",
      "description": "Coleção de registros de sinais"
    },
    "/access_codes/{codeId}": {
      "schema": "AccessCode",
      "description": "Coleção de códigos de acesso"
    }
  }
}
