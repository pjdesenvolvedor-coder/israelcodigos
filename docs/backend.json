{
  "entities": {
    "Webhook": {
      "title": "Webhook",
      "description": "Sinais recebidos via webhook",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string" },
        "payload": { "type": "object" },
        "createdAt": { "type": "string" }
      },
      "required": ["timestamp", "payload", "createdAt"]
    },
    "AccessCode": {
      "title": "AccessCode",
      "description": "Códigos de acesso do sistema",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "createdAt": { "type": "string" },
        "usedAt": { "type": "string" },
        "expiresAt": { "type": "string" }
      },
      "required": ["code", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/webhooks/{webhookId}": {
      "schema": "Webhook",
      "description": "Coleção de registros de sinais"
    },
    "/access_codes/{codeId}": {
      "schema": "AccessCode",
      "description": "Coleção de códigos de ativação"
    }
  }
}