{
  "entities": {
    "Webhook": {
      "title": "Webhook",
      "description": "Registros de sinais",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string" },
        "payload": { "type": "object" },
        "createdAt": { "type": "string" }
      }
    },
    "AccessCode": {
      "title": "AccessCode",
      "description": "Códigos de acesso",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/webhooks/{id}": { "schema": "Webhook", "description": "Coleção de sinais" },
    "/access_codes/{id}": { "schema": "AccessCode", "description": "Coleção de códigos" }
  }
}