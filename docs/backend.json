{
  "entities": {
    "Webhook": {
      "title": "Webhook",
      "description": "Registros de sinais recebidos via webhook",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "description": "ISO timestamp do recebimento" },
        "payload": { "type": "object", "description": "Dados brutos do sinal" },
        "createdAt": { "type": "string", "description": "Data de criação para ordenação" },
        "method": { "type": "string" }
      },
      "required": ["timestamp", "payload", "createdAt"]
    },
    "AccessCode": {
      "title": "AccessCode",
      "description": "Códigos de ativação de 30 dias",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "createdAt": { "type": "string" },
        "usedAt": { "type": "string" },
        "expiresAt": { "type": "string" }
      },
      "required": ["code", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/webhooks/{webhookId}": {
      "schema": "Webhook",
      "description": "Histórico de sinais em tempo real"
    },
    "/access_codes/{codeId}": {
      "schema": "AccessCode",
      "description": "Controle de ativações de usuários"
    }
  }
}